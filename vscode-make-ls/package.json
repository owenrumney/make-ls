{
  "name": "make-ls",
  "displayName": "Makefile Language Server",
  "description": "Language server for Makefiles — hover, completion, go-to-definition, references, diagnostics, symbols, formatting, and code actions.",
  "version": "0.1.15",
  "publisher": "owenrumney",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/owenrumney/make-ls"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "activationEvents": [
    "onLanguage:makefile"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "makefile",
        "aliases": [
          "Makefile",
          "makefile"
        ],
        "filenames": [
          "Makefile",
          "makefile",
          "GNUmakefile"
        ],
        "extensions": [
          ".mk",
          ".mak"
        ]
      }
    ],
    "configuration": {
      "title": "Makefile Language Server",
      "properties": {
        "make-ls.serverPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Absolute path to the `make-ls` server binary. When empty, the extension uses the bundled binary."
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "npm run compile -- --watch",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck && npm run compile",
    "format:check": "npx prettier@3.6.2 --check \"src/**/*.ts\" \"scripts/**/*.js\" \"*.json\"",
    "package": "npm run compile && node scripts/package.js",
    "vscode:prepublish": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.28.1",
    "ovsx": "^0.10.10",
    "typescript": "^5.0.0"
  }
}
